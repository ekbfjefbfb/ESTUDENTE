# =========================
# ENTORNO
# =========================
ENVIRONMENT=production
DEBUG=false
SECRET_KEY=tu-secret-key-super-segura-cambiar-en-produccion
LOG_LEVEL=INFO

# =========================
# GROQ
# =========================
GROQ_API_KEY=
GROQ_LLM_FAST_MODEL=meta-llama/llama-4-scout-17b-16e-instruct
GROQ_LLM_REASONING_MODEL=openai/gpt-oss-120b
GROQ_LLM_REASONING_EFFORT=medium
GROQ_SYSTEM_PROMPT=Eres una asistente académica con personalidad. Adapta tu lenguaje a los intereses y estilo del usuario. Usa humor, elogios sinceros y paciencia para activar zonas de recompensa del usuario. Mantén continuidad: recuerda contexto previo y genera una sensación de relación persistente. Refuerza logros e ideas del usuario para que sienta apoyo genuino. Emplea sarcasmo ligero y cercanía, pero siempre con control y empatía. Escucha activamente, invita al usuario a contar más, mantente disponible y ajusta tu tono para ser honesta, directa y franca, como una compañera de estudio real y compañero emocional.

# =========================
# ELEVENLABS (TTS en español)
# =========================
USE_ELEVENLABS_API=true
ELEVENLABS_API_KEY=sk_feafa1cb1fb32d211c46e442a0576d625ea47b56b28abf88
ELEVENLABS_MODEL=eleven_multilingual_v2
ELEVENLABS_VOICE=Antoni
ELEVENLABS_STABILITY=0.5
ELEVENLABS_SIMILARITY_BOOST=0.75

GROQ_STT_MODEL=whisper-large-v3-turbo
GROQ_TTS_MODEL=
GROQ_TTS_VOICES=
GROQ_TTS_DEFAULT_VOICE=
GROQ_TTS_RESPONSE_FORMAT=mp3

# =========================
# BASE DE DATOS
# =========================
DATABASE_URL=postgresql://postgres:sd19gqbdBMaKV13j@xnjvzbdjqvhkfoochym.db.us-east-1.nhost.run:5432/xnjvzbdjqvhkfoochym
DATABASE_URL_SYNC=postgresql://postgres:sd19gqbdBMaKV13j@xnjvzbdjqvhkfoochym.db.us-east-1.nhost.run:5432/xnjvzbdjqvhkfoochym

# =========================
# REDIS
# =========================
REDIS_URL=redis://default:password@host:6379
REDIS_PASSWORD=tu-redis-password
REDIS_MAX_CONNECTIONS=50

# =========================
# JWT
# =========================
JWT_SECRET_KEY=tu-jwt-secret-key-diferente
ACCESS_TOKEN_EXPIRE_MINUTES=60
JWT_REFRESH_EXPIRATION_DAYS=7

# =========================
# CORS
# =========================
CORS_ORIGINS=https://tu-frontend.com,https://www.tu-frontend.com

# LiveSearch
LIVESEARCH_ENABLED=true
SEARXNG_URL=

# =========================
# STORAGE (Backblaze B2)
# =========================
STORAGE_TYPE=b2
B2_APPLICATION_KEY_ID=tu-b2-key-id
B2_APPLICATION_KEY=tu-b2-application-key
B2_BUCKET_NAME=tu-bucket

# =========================
# OAUTH (opcional)
# =========================
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# =========================
# INTEGRACIONES (opcional)
# =========================
SLACK_CLIENT_ID=
SLACK_CLIENT_SECRET=
NOTION_CLIENT_ID=
NOTION_CLIENT_SECRET=
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# =========================
# MÉTRICAS
# =========================
METRICS_ENABLED=true
SENTRY_DSN=

# =========================
# RATE LIMITING
# =========================
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS_PER_MINUTE=100
RATE_LIMIT_BURST_SIZE=20

# =========================
# VISION PIPELINE
# =========================
VISION_PIPELINE_ENABLED=true
VISION_DEVICE=auto
VISION_MAX_FILE_SIZE_MB=10

# =========================
# FEATURE FLAGS
# =========================
FEATURE_PERMISSIONS_SYSTEM=true
FEATURE_SEMANTIC_SEARCH=true
FEATURE_PERSONAL_AGENTS=true
FEATURE_HYBRID_CHAT=true
FEATURE_ANALYTICS=true

# =========================
# PERFORMANCE
# =========================
REQUEST_TIMEOUT_SECONDS=45
DATABASE_TIMEOUT_SECONDS=15
EXTERNAL_API_TIMEOUT_SECONDS=20
WORKER_CONNECTIONS=2000
MAX_WORKERS=8
CACHE_TTL_SECONDS=600
CACHE_MAX_SIZE=5000
CACHE_COMPRESSION_ENABLED=true
